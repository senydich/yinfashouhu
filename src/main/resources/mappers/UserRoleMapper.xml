<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dtdx.dao.UserRoleDao">
    <select id="findRoleIdsByUserId" resultType="int">
        select role_id
        from t_user_role
        where user_id = #{userId}
    </select>

    <delete id="deleteByUserId">
        delete from t_user_role where user_id = #{userId}
    </delete>

    <delete id="deleteByRoleId">
        delete from t_user_role where role_id = #{roleId}
    </delete>

    <insert id="batchAddUserRoles">
        insert into t_user_role (user_id, role_id, create_date)
        values
        <foreach collection="roleIds" item="roleId" separator=",">
            (#{userId}, #{roleId}, now())
        </foreach>
    </insert>
</mapper>
